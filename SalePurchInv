        item_sql = """
        INSERT INTO invoice_items
        (invoice_item_id,invoice_type,invoice_number,hs_code,product_code,
        product_description,rate,uom,quantity,value_of_sales_excluding_st,
        sales_tax_applicable,retail_price_fixed_value,st_withheld_at_source,
