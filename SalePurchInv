#------------------------------
# VALIDATE INVOICE DATA
#------------------------------
def validate_invoice_json(data):

    required_fields = [
        "invoice_type",
        "invoice_number",
        "invoice_date",
        "buyer_seller_ntn_cnic",
        "buyer_seller_name",
        "destination_address",
        "sale_type",
        "items"
    ]

    for field in required_fields:
        if field not in data:
            return f"Missing field: {field}"

    if not isinstance(data["items"], list):
        return "Items must be an array"

    return None

# -----------------------------
# API 1 : CREATE INVOICE
# -----------------------------
@app.route('/create_invoice', methods=['POST'])
def create_invoice():

    data = request.json

    if not data:
        return jsonify({"error": "No JSON data received"}), 400

    validation_error = validate_invoice_json(data)

    if validation_error:
        return jsonify({"error": validation_error}), 400

    item_required = [
        "invoice_item_id",
        "product_code",
        "quantity",
        "rate"
    ]

    conn = get_db()
    cursor = conn.cursor()

    try:

        # -----------------------------
        # INSERT INVOICE HEADER
        # -----------------------------
        invoice_sql = """
        INSERT INTO invoices
        (invoice_type,invoice_number,invoice_date,buyer_seller_ntn_cnic,
        buyer_seller_name,destination_address,sale_type,
        total_sales_tax_applicable,total_retail_price_fixed_value,
