        VALUES (%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s)
        """

        cursor.execute(
            invoice_sql,
            (
                data["invoice_type"],
                data["invoice_number"],
                data["invoice_date"],
                data["buyer_seller_ntn_cnic"],
                data["buyer_seller_name"],
                data["destination_address"],
                data["sale_type"],
                data["total_sales_tax_applicable"],
                data["total_retail_price_fixed_value"],
                data["total_st_withheld_at_source"],
