        withholding_income_tax_applicable,wh_it_1,wh_it_2,
        wh_it_section_1,wh_it_section_2,total_values,discount,cvt)

        VALUES (%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s)
        """

        for item in data["items"]:

            cursor.execute(
                item_sql,
                (
                    item["invoice_item_id"],
                    item["invoice_type"],
                    item["invoice_number"],
                    item["hs_code"],
                    item["product_code"],
                    item["product_description"],
                    item["rate"],
                    item["uom"],
                    item["quantity"],
                    item["value_of_sales_excluding_st"],
                    item["sales_tax_applicable"],
                    item["retail_price_fixed_value"],
                    item["st_withheld_at_source"],
                    item["extra_tax"],
                    item["further_tax"],
                    item["sro_schedule_no"],
                    item["fed_payable"],
                    item["withholding_income_tax_applicable"],
                    item["wh_it_1"],
                    item["wh_it_2"],
                    item["wh_it_section_1"],
                    item["wh_it_section_2"],
                    item["total_values"],
                    item["discount"],
                    item["cvt"]
                )
            )

        conn.commit()

        return jsonify({
            "message": "Invoice inserted successfully",
            "invoice_type": data["invoice_type"],
            "invoice_number": data["invoice_number"]
        })

    except Exception as e:

        conn.rollback()
        return jsonify({"error": str(e)}), 400

    finally:

        cursor.close()
        conn.close()


# -----------------------------
# API 2 : GET INVOICE
# -----------------------------
@app.route('/get_invoice/<int:invoice_type>/<int:invoice_number>', methods=['GET'])
def get_invoice(invoice_type, invoice_number):

    conn = get_db()
    cursor = conn.cursor(dictionary=True)

    # invoice header
    cursor.execute(
        """
        SELECT * FROM invoices
        WHERE invoice_type=%s AND invoice_number=%s
        """,
        (invoice_type, invoice_number)
    )

    invoice = cursor.fetchone()

    if not invoice:
        return jsonify({"message": "Invoice not found"}), 404

    # invoice items
    cursor.execute(
        """
        SELECT *
        FROM invoice_items
        WHERE invoice_type=%s AND invoice_number=%s
        """,
        (invoice_type, invoice_number)
    )

    items = cursor.fetchall()

    invoice["items"] = items

    cursor.close()
    conn.close()

    return jsonify(invoice)


